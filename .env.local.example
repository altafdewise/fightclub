# ── Fight Club — Season One, Series Two ──────────────────────────
# Razorpay. KYC is done — paste LIVE keys (rzp_live_…) here to go live.
# ⚠️ SWAP WITH LIVE VALUES BEFORE DEPLOY. No code change needed.
# Use test keys (rzp_test_…) while developing.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_     # client checkout key
RAZORPAY_KEY_ID=rzp_test_                 # server (alias; falls back to NEXT_PUBLIC_ above)
RAZORPAY_KEY_SECRET=                      # server-only secret

# Supabase service-role key — SERVER ONLY, never exposed to the client.
# The code reads SUPABASE_SERVICE_ROLE_KEY first, then SUPABASE_SERVICE_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# Resend sender for fight club ticket emails.
# Code reads SENDER_EMAIL → FIGHTCLUB_FROM_EMAIL → FROM_EMAIL.
SENDER_EMAIL=Fight Club HYD <fightclub@brutal.fit>
FIGHTCLUB_FROM_EMAIL=Fight Club HYD <fightclub@brutal.fit>

# WhatsApp broadcast invite link — success page + email. Placeholder for now.
NEXT_PUBLIC_WHATSAPP_INVITE_URL=https://chat.whatsapp.com/
WHATSAPP_INVITE_URL=https://chat.whatsapp.com/

# Admin dashboard gate (/fightclub/admin). Server-checked; never sent to client.
# ⚠️ SET A STRONG VALUE BEFORE DEPLOY.
ADMIN_PASSWORD=
